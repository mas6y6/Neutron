{
  "name": "Neutron",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "npm run build-ts && npm run copy-assets",
    "build-ts": "tsc",
    "copy-assets": "cpx \"src/desktop_client/{frontend,assets}/**/*\" dist/desktop_client",
    "start:client": "npm run build && electron ./dist/run-client.js",
    "start:server": "npm run build && node ./dist/run-server.js",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.1",
    "cpx": "^1.2.1",
    "electron": "^40.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "node-notifier": "^10.0.1"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8"
  }
}
