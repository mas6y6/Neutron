{
  "name": "Neutron",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "build": "npm run build-ts && npm run copy-assets",
    "build-ts": "tsc",
    "copy-assets": "cpx \"src/desktop_client/{frontend,assets}/**/*\" dist/desktop_client",
    "start:client": "npm run build && electron ./dist/run-client.js",
    "start:server": "npm run build && node ./dist/run-server.js",
    "test:server": "npm run build && node ./dist/run-server.js --config test/config.yml",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.1",
    "@types/ws": "^8.18.1",
    "cpx": "^1.2.1",
    "electron": "^40.6.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "nexe": "^5.0.0-beta.4",
    "node-notifier": "^10.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "got": "^11.8.5",
    "http-cache-semantics": "^4.1.1"
  }
}
